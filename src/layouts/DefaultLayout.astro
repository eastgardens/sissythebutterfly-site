---
import '../styles/tailwind.css'
import '../assets/scss/index.scss'
import themeConfig from '@theme-config'
import { SEO } from 'astro-seo'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import { ClientRouter } from 'astro:transitions'
import type { ImageMetadata } from 'astro'
import { analyticsEnabled, cfBeaconConfig } from '@config/analytics'

interface Props {
  /**
   * The title of the page
   */
  title?: string
  /**
   * The description of the page
   */
  description?: string
  /**
   * The URL of the page
   */
  url?: string
  /**
   * The image path for social sharing (can be ImageMetadata or string path)
   */
  image?: ImageMetadata | string | null
  /**
   * Alt text describing the social-share image (og:image:alt / twitter:image:alt)
   */
  imageAlt?: string
  /**
   * The author of the page
   */
  author?: string
  /**
   * The type of content (default: 'website')
   */
  type?: 'website' | 'article'
  /**
   * Whether to use the title template (default: true)
   * Set to false to use the title as-is without appending site name
   */
  useTitleTemplate?: boolean
}

const {
  title = themeConfig.seo.title,
  description = themeConfig.seo.description ?? '',
  url = Astro.url.href,
  image = themeConfig.seo.image ?? null,
  imageAlt = themeConfig.seo.title,
  author = themeConfig.seo.author ?? '',
  type = 'website',
  useTitleTemplate = true,
} = Astro.props

// For social sharing, we need the full absolute URL
// If image is an ImageMetadata object, use its src, otherwise treat as string path
const imagePath = image ? (typeof image === 'string' ? image : image.src) : '/social-preview-image.png'
const imageUrl = new URL(imagePath, Astro.site).href

// Organization structured data (WEBSITE-BUILD-SPEC §5 — conservative, true-only).
const logoPath = themeConfig.logo
  ? typeof themeConfig.logo === 'string'
    ? themeConfig.logo
    : themeConfig.logo.src
  : '/favicon-512.png'
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: themeConfig.name,
  url: new URL('/', Astro.site).href,
  logo: new URL(logoPath, Astro.site).href,
}
---

<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <!-- Pinterest domain verification (claim + Rich Pins) -->
    <meta name="p:domain_verify" content="d2f945698fb5dcbbf34255e79b283ad1" />

    <!-- favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- theme colors from config -->
    <style
      define:vars={{
        brandPrimary: themeConfig.colors.primary,
        brandSecondary: themeConfig.colors.secondary,
        brandNeutral: themeConfig.colors.neutral,
        brandOutline: themeConfig.colors.outline,
      }}
    >
      :global(:root) {
        --brand-primary: var(--brandPrimary);
        --brand-secondary: var(--brandSecondary);
        --brand-neutral: var(--brandNeutral);
        --brand-outline: var(--brandOutline);
      }
    </style>

    <SEO
      title={title}
      titleTemplate={useTitleTemplate ? `%s · ${themeConfig.name}` : undefined}
      titleDefault={themeConfig.seo.title}
      description={description}
      canonical={url}
      openGraph={{
        basic: {
          title: title,
          type: type,
          image: imageUrl,
          url: url,
        },
        optional: {
          description: description,
        },
        image: {
          alt: imageAlt,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: imageUrl,
        imageAlt: imageAlt,
      }}
      extend={{
        meta: [
          {
            name: 'author',
            content: author,
          },
        ],
      }}
    />

    <!-- Organization structured data (schema.org) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} is:inline />

    <!-- Enable Astro View Transitions for all browsers -->
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <Footer />

    <script>
      // Provider-agnostic click tracking (runbook 2.3d). Captures [data-event] clicks
      // (retailer_click_*, newsletter_submit, printable_download_*) into a queue for a future
      // analytics sink. No third party, no PII: privacy-safe by construction for a children's
      // brand. Delegated on document, so it survives view transitions without re-binding.
      //
      // ── EVENT-SINK SEAM (WEBSITE-BUILD-SPEC D3) ────────────────────────────────────────────
      // Cloudflare Web Analytics (wired below) is DASHBOARD-ONLY: it gives automatic PAGEVIEWS
      // but has NO custom-event API, so this array is intentionally NOT drained today — the
      // events are captured and left queued on purpose. They become valuable when the operator
      // self-hosts Umami/Plausible on the NAS: at that point add a drain here (post the queued
      // events to the sink's collect endpoint) — that is the precise retailer-click /
      // printable-download upgrade path. Until then, KDP dashboard = sales truth, CF = traffic.
      // See src/config/analytics.ts for the full seam + upgrade notes.
      ;(function () {
        window.__sissyEvents = window.__sissyEvents || []
        document.addEventListener('click', function (e) {
          const el = e.target && e.target.closest && e.target.closest('[data-event]')
          if (!el) return
          window.__sissyEvents.push({
            event: el.getAttribute('data-event'),
            href: el.getAttribute('href') || undefined,
            at: Date.now(),
          })
        })
      })()
    </script>

    {/*
      Cloudflare Web Analytics beacon (WEBSITE-BUILD-SPEC D3). Standalone JS beacon — free,
      cookieless, no PII, COPPA-friendly; works on GitHub Pages with no proxy and no DNS change.
      Gated behind CF_BEACON_TOKEN in src/config/analytics.ts: ships INERT (nothing injected)
      until the operator pastes a real token. `is:inline` keeps Astro from bundling this
      third-party script; `spa:true` tracks ClientRouter (View Transitions) client-side navs.
    */}
    {
      analyticsEnabled && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify(cfBeaconConfig)}
        />
      )
    }
    <style lang="scss" is:global>
      @use 'scss/base/mixins' as *;

      // sticky footer on low content pages
      html,
      body {
        height: 100%;
      }

      body {
        display: flex;
        flex-direction: column;
        overflow-x: clip;

        main {
          flex: 1 0 auto;
        }

        footer {
          flex-shrink: 0;
        }
      }

      pre {
        border: 2px solid var(--link-color);
        border-radius: 0.35rem;
        padding: 1rem;
      }

      .card {
        a {
          @include text-decoration(transparent, var(--foreground-color), 4px, 2px);
        }
      }
    </style>
  </body>
</html>
