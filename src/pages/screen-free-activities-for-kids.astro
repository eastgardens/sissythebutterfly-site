---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { printables, type Printable } from '@data/printables'
import heroArt from '@assets/img/scenes/scene-pond.png'

/**
 * SEO resource page — target cluster: "screen-free activities for kids ages 3-7".
 * Original guidance for parents who want off-screen time that actually holds a child's attention,
 * curating our real printables (calm-down, movement, board game, make-your-own). Soft book link,
 * cross-links to sibling guides, email capture. Not thin: real, usable ideas.
 */
const pick = (slugs: string[]): Printable[] =>
  slugs
    .map((slug) => printables.find((p) => p.slug === slug))
    .filter((p): p is Printable => Boolean(p))

const screenFreeSet = pick([
  'rainbow-breaths-calm-down-card',
  'the-flutter-song-lyric-and-action-sheet',
  'sissys-meadow-hop-board-game',
  'make-your-own-meadow-map',
  'make-a-paper-butterfly',
  'meadow-friends-word-search',
])

const pageUrl = new URL('/screen-free-activities-for-kids/', Astro.site).href
const heroUrl = new URL(heroArt.src, Astro.site).href
const logoUrl = new URL('/favicon-512.png', Astro.site).href

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Screen-Free Activities for Kids Ages 3-7',
  description:
    'Calm, screen-free activities for kids ages 3-7 that actually hold their attention — free printable calm-down cards, movement songs, a board game, and crafts from the meadow.',
  image: heroUrl,
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  publisher: {
    '@type': 'Organization',
    name: 'Sissy the Butterfly',
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  datePublished: '2026-07-13',
  dateModified: '2026-07-13',
  mainEntityOfPage: pageUrl,
}

const ideas = [
  {
    name: 'A five-minute calm-down',
    body: 'When everyone is frazzled, a Rainbow Breaths card gives little hands something to trace while big feelings settle. It is our most-reached-for sheet for a reason.',
  },
  {
    name: 'Wiggle it out',
    body: 'Put on a movement song and flutter, hop, and stretch. The Flutter Song action sheet turns antsy energy into a game — no screen, plenty of giggles.',
  },
  {
    name: 'Play a real board game',
    body: 'Print the Meadow Hop board game, grab a coin and a button for tokens, and take turns. Turn-taking and counting hide inside the fun.',
  },
  {
    name: 'Build a small world',
    body: 'Hand your child a blank meadow map and let them draw the world. Open-ended making holds attention far longer than anything that plays for them.',
  },
]

const faqs = [
  {
    q: 'What are good screen-free activities for a 3 to 7 year old?',
    a: 'Hands-on, open-ended things: coloring, simple crafts, movement games, board games, and make-your-own drawing. The best ones let the child make choices, so they stay engaged without a screen doing the work.',
  },
  {
    q: 'How do I get my child off screens without a meltdown?',
    a: 'Have the next thing ready before you turn the screen off. A printed calm-down card or a quick craft on the table gives them somewhere to land, which makes the switch far smoother.',
  },
  {
    q: 'Are these activities really free?',
    a: 'Yes — every printable here is free to download and print, and they stay free. You just need paper and a printer.',
  },
]
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<DefaultLayout
  title="Screen-Free Activities for Kids Ages 3-7"
  description="Calm, screen-free activities for kids ages 3-7 that actually hold their attention — free printable calm-down cards, movement songs, a board game, and butterfly crafts."
  image={heroArt}
  imageAlt="A quiet meadow pond ringed with flowers and reeds — a calm scene from the world of Sissy the Butterfly."
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  <PageHeader
    title="Screen-Free Activities for Kids Ages 3-7"
    subtitle="Calm, hands-on fun that actually holds their attention — free printables you can start in the next five minutes."
    featuredImage={heroArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <p>
          Some days you just need the screen to go off — without the whole afternoon falling apart.
          The trick is not a longer list of rules; it is having something ready that a small child
          actually wants to do with their hands.
        </p>
        <p>
          These are the screen-free activities we reach for most: gentle, teacher-created, and made
          for ages 3 to 7. Each one is a free printable, so you can go from "screen off" to "busy
          hands" before the fuss even starts.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Four screen-free ideas to try today</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-6 text-lg">
        {
          ideas.map((idea) => (
            <div>
              <Heading level="h3">{idea.name}</Heading>
              <p class="mt-1">{idea.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Free printables to start right now</Heading>
      <p class="text-lg">
        Print one, keep a couple in your bag, and you always have a screen-free option on hand.
      </p>
      <PrintableGrid items={screenFreeSet} />
      <p class="text-lg">
        Browse more by type: <a href="/printables/activities/">calm-down &amp; movement activities</a>,
        <a href="/printables/music/">songs &amp; movement sheets</a>, and
        <a href="/printables/puzzles/">puzzles &amp; games</a>.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Tips that make screen-free stick</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <ul class="flex list-disc flex-col gap-2 pl-6">
          <li>
            <strong>Set it up first.</strong> Have the printable on the table before the screen
            goes off. A ready activity beats a rule every time.
          </li>
          <li>
            <strong>Keep a rainy-day folder.</strong> Print a small stack and stash it. Boredom
            hits fastest when you have nothing on hand.
          </li>
          <li>
            <strong>Join in for two minutes.</strong> Start the coloring or the first board-game
            turn with them. Your two minutes buys their twenty.
          </li>
          <li>
            <strong>Let calm count too.</strong> Screen-free does not have to mean loud. A breathing
            card on the couch is a perfectly good activity.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">More free resource guides</Heading>
      <ul class="mx-auto flex max-w-2xl list-disc flex-col gap-3 pl-6 text-lg">
        <li><a href="/free-butterfly-printables/">Free butterfly printables for kids</a></li>
        <li><a href="/butterfly-crafts-for-kids/">Butterfly crafts for kids</a></li>
        <li>
          <a href="/butterfly-life-cycle-activities/">Butterfly life cycle activities for preschoolers</a>
        </li>
      </ul>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Frequently asked questions</Heading>
      <dl class="mx-auto flex max-w-2xl flex-col gap-6 text-lg">
        {
          faqs.map((item) => (
            <div>
              <dt class="font-bold">{item.q}</dt>
              <dd class="mt-1">{item.a}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto max-w-2xl text-lg">
        <Heading level="h2">A gentle wind-down, too</Heading>
        <p class="mt-3">
          Some of the best screen-free time is a story on a lap. If you are building a calmer
          evening routine, <a href="/book/">the Sissy the Butterfly book</a> is a short, warm
          read-aloud for ages 3 to 7 — there whenever you are ready, no pressure at all.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
