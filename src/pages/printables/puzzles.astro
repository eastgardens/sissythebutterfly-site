---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import { CATEGORY_META, printablesByCategory } from '@data/printables'

/**
 * Puzzles & Games — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2). Real printables now
 * live here: word search, connect-the-dots, counting sheet, and a board game — all rendered by the
 * deterministic mascotAI puzzle generators (no model text, reproducible by seed).
 */
const meta = CATEGORY_META['puzzles']
const items = printablesByCategory('puzzles')
---

<DefaultLayout title={meta.seoTitle} description={meta.seoDescription}>
  <PageHeader title={meta.pageTitle} subtitle={meta.subtitle} />
  <section class="my-24">
    <div class="container space-content">
      <PrintableGrid items={items} />
      <p class="mt-16 text-center text-base">
        More puzzles are on the way — everything here is always free, teacher-created, and made for
        grown-ups to share with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
