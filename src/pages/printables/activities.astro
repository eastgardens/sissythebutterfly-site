---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import { CATEGORY_META, printablesByCategory } from '@data/printables'

/**
 * Activities — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2). Real printables now live
 * here: a validation-first SEL calm-down card and more, teacher-created and screen-free.
 */
const meta = CATEGORY_META['activities']
const items = printablesByCategory('activities')
---

<DefaultLayout title={meta.seoTitle} description={meta.seoDescription}>
  <PageHeader title={meta.pageTitle} subtitle={meta.subtitle} />
  <section class="my-24">
    <div class="container space-content">
      <PrintableGrid items={items} />
      <p class="mt-16 text-center text-base">
        More activities are on the way — everything here is always free, teacher-created, and made
        for grown-ups to share with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
