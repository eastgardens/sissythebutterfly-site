---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { CATEGORY_META, printablesByCategory } from '@data/printables'

/**
 * Make Your Own — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2). Real printables now
 * live here: make-your-own templates where the child is the author (their imagination is the magic).
 */
const meta = CATEGORY_META['make-your-own']
const items = printablesByCategory('make-your-own')
---

<DefaultLayout title={meta.seoTitle} description={meta.seoDescription}>
  <PageHeader title={meta.pageTitle} subtitle={meta.subtitle} />
  <section class="my-24">
    <div class="container space-content">
      <PrintableGrid items={items} />
      <p class="mt-16 text-center text-base">
        More make-your-own templates are on the way — everything here is always free,
        teacher-created, and made for grown-ups to share with their children.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
