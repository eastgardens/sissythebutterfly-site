---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'

/**
 * Music & Songs — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2).
 * Items populate from the content engine at 2.5 (every pin links to its item page here).
 */
---

<DefaultLayout title="Music & Songs — Sissy the Butterfly" description="Kids songs and movement sheets from Sissy the Butterfly: printable lyric and action sheets to sing, buzz, and flutter — screen-free family fun.">
  <PageHeader title="Music & Songs" subtitle="Lyric and action sheets, movement songs, and the Buzz Dance — print, sing, and wiggle." />
  <section class="my-24">
    <div class="container">
      <p class="mx-auto max-w-2xl text-center text-lg">
        This shelf is being stocked! The first free printables arrive with our grand opening.
        Everything here will always be free, teacher-created, and made for grown-ups to share
        with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
