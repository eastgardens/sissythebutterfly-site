---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import { CATEGORY_META, printablesByCategory } from '@data/printables'

/**
 * Music & Songs — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2). Real printables now
 * live here: piggyback lyric + action sheets (the Wiggles model) — a line, its action, repeat.
 */
const meta = CATEGORY_META['music']
const items = printablesByCategory('music')
---

<DefaultLayout title={meta.seoTitle} description={meta.seoDescription}>
  <PageHeader title={meta.pageTitle} subtitle={meta.subtitle} />
  <section class="my-24">
    <div class="container space-content">
      <PrintableGrid items={items} />
      <p class="mt-16 text-center text-base">
        More songs are on the way — everything here is always free, teacher-created, and made for
        grown-ups to share with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
