---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import { CATEGORY_META, printablesByCategory } from '@data/printables'

/**
 * Coloring Pages — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2). Real printables now
 * live here: every sheet is a free, teacher-created PDF rendered by the mascotAI generators.
 */
const meta = CATEGORY_META['coloring']
const items = printablesByCategory('coloring')
---

<DefaultLayout title={meta.seoTitle} description={meta.seoDescription}>
  <PageHeader title={meta.pageTitle} subtitle={meta.subtitle} />
  <section class="my-24">
    <div class="container space-content">
      <PrintableGrid items={items} />
      <p class="mt-16 text-center text-base">
        More coloring pages are on the way — everything here is always free, teacher-created, and
        made for grown-ups to share with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
