---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'

/**
 * Kids Crafts — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2).
 * Items populate from the content engine at 2.5 (every pin links to its item page here).
 */
---

<DefaultLayout title="Kids Crafts — Sissy the Butterfly">
  <PageHeader title="Kids Crafts" subtitle="Simple butterfly crafts and meadow make-alongs for kids, using everyday household materials." />
  <section class="my-24">
    <div class="container">
      <p class="mx-auto max-w-2xl text-center text-lg">
        This shelf is being stocked! The first free printables arrive with our grand opening.
        Everything here will always be free, teacher-created, and made for grown-ups to share
        with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
