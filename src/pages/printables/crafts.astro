---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import { CATEGORY_META, printablesByCategory } from '@data/printables'

/**
 * Kids Crafts — Pinterest-search-matched landing (WEBSITE-BUILD-SPEC §2). Real printables now live
 * here: free, teacher-created craft cards with a grown-up helper split + verbatim safety notes.
 */
const meta = CATEGORY_META['crafts']
const items = printablesByCategory('crafts')
---

<DefaultLayout title={meta.seoTitle} description={meta.seoDescription}>
  <PageHeader title={meta.pageTitle} subtitle={meta.subtitle} />
  <section class="my-24">
    <div class="container space-content">
      <PrintableGrid items={items} />
      <p class="mt-16 text-center text-base">
        More crafts are on the way — everything here is always free, teacher-created, and made for
        grown-ups to share with their children.
      </p>
    </div>
  </section>
</DefaultLayout>
