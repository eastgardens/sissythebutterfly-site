---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import Feature from '@components/Feature.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import {
  CATEGORY_META,
  CATEGORY_ORDER,
  categoryCount,
  featuredPrintables,
  totalPrintables,
} from '@data/printables'
import bannerArt from '@assets/img/scenes/scene-butterfly-garden.png'

/**
 * Printables & Activities — THE FRONT DOOR (WEBSITE-BUILD-SPEC §2; taxonomy LOCKED, 7 categories).
 * The garden is planted: real free printables now live under every category. Category cards show
 * live counts; a featured strip surfaces the strongest sheets. Data + metadata are DRY in
 * src/data/printables.ts (the per-sheet manifest is generated by the mascotAI renderer).
 */
const categories = CATEGORY_ORDER.map((id) => ({
  meta: CATEGORY_META[id],
  count: categoryCount(id),
}))
const featured = featuredPrintables()
---

<DefaultLayout
  title="Free Printables & Activities"
  description="Free printable activities for kids ages 3-7: coloring pages, crafts, puzzles, songs, teaching guides, and make-your-own fun — teacher-created, always free."
  image={bannerArt}
  imageAlt="A bright butterfly garden full of big flowers — the printables & activities front door."
>
  <PageHeader
    title="Printables & Activities"
    subtitle="Free, teacher-created, and ready to print. Grown-ups download; everyone plays."
    featuredImage={bannerArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Browse by category</Heading>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
        {
          categories.map(({ meta, count }) => (
            <a href={`/printables/${meta.id}/`} class="category-card">
              <Feature level="h3" icon={meta.icon} title={meta.navTitle}>
                {meta.teaser}
                <span class="category-count">
                  {count} free {count === 1 ? 'printable' : 'printables'}
                </span>
              </Feature>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="my-24">
        <div class="container space-content">
          <Heading level="h2">Fresh from the meadow</Heading>
          <p class="text-lg">
            {totalPrintables} free printables and counting — every one teacher-created and
            print-ready. Here are a few favorites to start with.
          </p>
          <PrintableGrid items={featured} />
        </div>
      </section>
    )
  }

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Helpful guides</Heading>
      <p class="text-lg">
        New here? These free guides curate the best printables for a specific need.
      </p>
      <ul class="flex list-disc flex-col gap-3 pl-6 text-lg">
        <li><a href="/free-butterfly-printables/">Free butterfly printables for kids</a></li>
        <li>
          <a href="/butterfly-life-cycle-activities/">Butterfly life cycle activities for preschoolers</a>
        </li>
        <li><a href="/butterfly-crafts-for-kids/">Butterfly crafts for kids</a></li>
        <li><a href="/screen-free-activities-for-kids/">Screen-free activities for kids ages 3-7</a></li>
      </ul>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Never miss a new printable</Heading>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>

<style>
  .category-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .category-count {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: light-dark(var(--color-primary-400), var(--color-primary-200));
  }
</style>
