---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { printables, type Printable } from '@data/printables'
import heroArt from '@assets/img/scenes/scene-butterfly-garden.png'

/**
 * SEO resource page — target cluster: "kids songs with actions" / "movement activities for
 * preschoolers" / "action songs for circle time". Curates our real music + movement sheets with
 * genuine guidance on why moving while singing helps a young child. Gentle, teacher-created.
 */
const pick = (slugs: string[]): Printable[] =>
  slugs
    .map((slug) => printables.find((p) => p.slug === slug))
    .filter((p): p is Printable => Boolean(p))

const songSet = pick([
  'the-flutter-song-lyric-and-action-sheet',
  'the-kindness-song-lyric-and-action-sheet',
])

const movementSet = pick(['flutter-and-freeze-movement-card', 'sissys-meadow-hop-board-game'])

const pageUrl = new URL('/kids-songs-with-actions/', Astro.site).href
const heroUrl = new URL(heroArt.src, Astro.site).href
const logoUrl = new URL('/favicon-512.png', Astro.site).href

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Kids Songs with Actions',
  description:
    'Free printable action songs and movement activities for kids ages 3-7 — familiar tunes with new meadow words, and an action for every line. Teacher-created, print and sing.',
  image: heroUrl,
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  publisher: {
    '@type': 'Organization',
    name: 'Sissy the Butterfly',
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  mainEntityOfPage: pageUrl,
}

const faqs = [
  {
    q: 'What age are action songs good for?',
    a: 'Action songs suit roughly ages 3 to 7. Younger children copy the movements long before they catch every word, and that is exactly the point — joining in with hands and feet comes first, and the words arrive on their own.',
  },
  {
    q: 'Why add actions to a song at all?',
    a: 'Moving while singing gives a child two ways to hold on to the same idea. Hands and voice work together, the tune carries the words, and the wiggles find somewhere useful to go. It also keeps a group together without anyone needing to sit still.',
  },
  {
    q: 'Do I need to be able to sing?',
    a: 'Not even slightly. These use tunes you already half-know, and children are the most forgiving audience there is. If you are unsure, let the actions lead and let the singing be a mumble — they will still join in.',
  },
  {
    q: 'Are these songs free to print?',
    a: 'Yes — every lyric and action sheet here is a free, teacher-created PDF. Print on regular letter-size paper; one copy for the grown-up is usually plenty.',
  },
]
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<DefaultLayout
  title="Kids Songs with Actions"
  description="Free printable action songs and movement activities for kids ages 3-7 — familiar tunes with new meadow words, and an action for every line. Teacher-created, print and sing."
  image={heroArt}
  imageAlt="A butterfly garden in bloom from the world of Sissy the Butterfly."
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  <PageHeader
    title="Kids Songs with Actions"
    subtitle="Familiar tunes, new meadow words, and an action for every line — free to print, for ages 3 to 7."
    featuredImage={heroArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <p>
          A song a child can <em>do</em> is a song they remember. Add a flutter of the hands to a
          tune they already know, and suddenly the words have somewhere to live — in the movement,
          in the rhythm, in the giggle at the end when everybody freezes.
        </p>
        <p>
          Each sheet below borrows a tune you have known your whole life and gives it new meadow
          words, with a simple action printed beside every line. Free, teacher-created, and ready to
          print.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Free printable action songs</Heading>
      <p class="text-lg">
        Two songs, each set to a tune you already half-know, with an action for every line.
      </p>
      <PrintableGrid items={songSet} />
      <p class="text-lg">
        More in the full <a href="/printables/music/">music collection</a>.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Movement activities for wiggly days</Heading>
      <p class="text-lg">
        For when the singing is done and the wiggles are not — a freeze game and a hopping board
        game, both free to print.
      </p>
      <PrintableGrid items={movementSet} />
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Tips for singing together</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <ul class="flex list-disc flex-col gap-2 pl-6">
          <li>
            <strong>Do the actions first.</strong> Walk through the movements once with no singing at
            all. Children who are shy about their voice will happily join in with their hands.
          </li>
          <li>
            <strong>Go slower than feels natural.</strong> A tune at half speed gives a three-year-old
            time to find the next word. You can always speed up on the second round — and speeding up
            is half the fun.
          </li>
          <li>
            <strong>Let them lead a verse.</strong> Ask what action a line should have and use their
            idea, even if it is a very strange idea. Ownership beats accuracy every time.
          </li>
          <li>
            <strong>Stop while they still want more.</strong> Two rounds and a big finish leaves them
            asking for it again tomorrow.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Questions grown-ups ask</Heading>
      <div class="mx-auto max-w-2xl">
        <dl class="flex flex-col gap-6">
          {
            faqs.map((item) => (
              <div>
                <dt class="text-lg font-bold">{item.q}</dt>
                <dd class="mt-2 text-lg">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto max-w-2xl text-lg">
        <Heading level="h2">The songs come from a story</Heading>
        <p class="mt-3">
          Sissy is a little butterfly learning to be brave, and these are the songs of her meadow.
          <a href="/book/">Her picture book</a> is a gentle read-aloud whenever you&rsquo;re ready.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
