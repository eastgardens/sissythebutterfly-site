---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { printables, type Printable } from '@data/printables'
import heroArt from '@assets/img/scenes/scene-pond.png'

/**
 * SEO resource page — target cluster: "fine motor activities for preschoolers" / "fine motor skills
 * printables" / "scissor skills / cutting activities for kids" / "pencil control worksheets".
 * Curates our real maze, dot-to-dot, matching, craft, and drawing sheets with genuine guidance on
 * building the small hand muscles behind writing. Gentle, teacher-created.
 */
const pick = (slugs: string[]): Printable[] =>
  slugs
    .map((slug) => printables.find((p) => p.slug === slug))
    .filter((p): p is Printable => Boolean(p))

const pencilSet = pick([
  'butterfly-maze',
  'butterfly-connect-the-dots',
  'flower-connect-the-dots',
  'match-the-meadow',
])
const cuttingSet = pick(['make-a-paper-butterfly', 'paper-plate-butterfly'])
const drawingSet = pick(['design-your-own-butterfly-wings'])

const pageUrl = new URL('/fine-motor-activities-for-preschoolers/', Astro.site).href
const heroUrl = new URL(heroArt.src, Astro.site).href
const logoUrl = new URL('/favicon-512.png', Astro.site).href

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Fine Motor Skills Activities for Preschoolers',
  description:
    'Free fine motor activities for preschoolers ages 3-7 — mazes and dot-to-dots for pencil control, a matching sheet, and cut-and-fold crafts for scissor skills. Teacher-created, print and play.',
  image: heroUrl,
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  publisher: {
    '@type': 'Organization',
    name: 'Sissy the Butterfly',
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  datePublished: '2026-07-16',
  dateModified: '2026-07-16',
  mainEntityOfPage: pageUrl,
}

const faqs = [
  {
    q: 'What are fine motor skills, and why do they matter?',
    a: 'Fine motor skills are the small, precise movements of the hands and fingers — holding a crayon, using scissors, doing up a button. They are the foundation writing is built on, which is why so much of preschool is quietly about strengthening little hands.',
  },
  {
    q: 'What age should fine motor practice start?',
    a: 'It is already happening from toddlerhood, long before a child holds a pencil properly. Around ages 3 to 5 is a lovely window for the sheets here — mazes, dot-to-dots, and cutting — but there is no race. A relaxed hand learns faster than a rushed one.',
  },
  {
    q: 'My child grips the crayon in a fist. Is that a problem?',
    a: 'Not at this age. A fist grip is a normal early stage, and it changes on its own as the hand grows stronger. Short bursts of drawing, cutting, and threading do more to help than any correction. Try a broken crayon or a golf pencil — a small tool nudges small fingers into place.',
  },
  {
    q: 'Are these fine motor printables free?',
    a: 'Yes — every sheet here is a free, teacher-created PDF. Print on regular letter-size paper. For the cutting crafts, a pair of safety scissors and a grown-up nearby is all you need.',
  },
]
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<DefaultLayout
  title="Fine Motor Skills Activities for Preschoolers"
  description="Free fine motor activities for preschoolers ages 3-7 — mazes and dot-to-dots for pencil control, a matching sheet, and cut-and-fold crafts for scissor skills. Teacher-created, print and play."
  image={heroArt}
  imageAlt="A calm meadow pond from the world of Sissy the Butterfly."
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  <PageHeader
    title="Fine Motor Skills Activities for Preschoolers"
    subtitle="Mazes, dot-to-dots, and cut-and-fold crafts that quietly strengthen little hands — free to print, for ages 3 to 7."
    featuredImage={heroArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <p>
          Long before a child can write their name, their hands are doing the groundwork — pinching,
          tracing, snipping, and gripping. Those small muscles are what a pencil will one day rely
          on, and the best way to build them is not drills but play a child actually wants to do.
        </p>
        <p>
          The sheets below hide real hand-strengthening work inside a maze, a puzzle, and a craft.
          No child will notice they are practicing. All free, all teacher-created.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Pencil control and tracing</Heading>
      <p class="text-lg">
        A maze to steer through, two dot-to-dots that end in a picture, and a matching sheet where a
        careful line is the whole game — gentle practice for the grip that writing needs.
      </p>
      <PrintableGrid items={pencilSet} />
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Scissor skills and cutting</Heading>
      <p class="text-lg">
        Cutting is one of the best hand workouts there is. These two crafts give little scissors
        something to do — with a grown-up helper note and a safety line on every sheet.
      </p>
      <PrintableGrid items={cuttingSet} />
      <p class="text-lg">
        More in the full <a href="/printables/crafts/">crafts collection</a>.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Free drawing for busy fingers</Heading>
      <p class="text-lg">
        Open-ended drawing builds control just as well as tracing does — and a blank pair of wings
        invites a child to fill every inch.
      </p>
      <PrintableGrid items={drawingSet} />
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Ways to build strong little hands</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <ul class="flex list-disc flex-col gap-2 pl-6">
          <li>
            <strong>Work up high.</strong> Tape a sheet to the wall or the fridge. Drawing on a
            vertical surface builds the wrist and shoulder strength a good pencil grip sits on top
            of.
          </li>
          <li>
            <strong>Keep it short.</strong> Five focused minutes beats a whole worksheet. Little
            hands tire quickly, and a tired hand practices a worse grip, not a better one.
          </li>
          <li>
            <strong>Let them cut real things.</strong> Snipping a straw into beads or a card into
            confetti is scissor practice in disguise, and far more tempting than a dotted line.
          </li>
          <li>
            <strong>Praise the effort, not the neatness.</strong> A wobbly line drawn with focus is
            worth more than a tidy one traced with a sigh. The trying is the muscle.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Questions grown-ups ask</Heading>
      <div class="mx-auto max-w-2xl">
        <dl class="flex flex-col gap-6">
          {
            faqs.map((item) => (
              <div>
                <dt class="text-lg font-bold">{item.q}</dt>
                <dd class="mt-2 text-lg">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">More gentle guides</Heading>
      <ul class="mx-auto flex max-w-2xl list-disc flex-col gap-3 pl-6 text-lg">
        <li><a href="/butterfly-crafts-for-kids/">Butterfly crafts for kids</a></li>
        <li><a href="/printable-counting-worksheets/">Printable counting worksheets for kids</a></li>
        <li><a href="/free-butterfly-printables/">All our free butterfly printables</a></li>
      </ul>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto max-w-2xl text-lg">
        <Heading level="h2">The sheets come from a story</Heading>
        <p class="mt-3">
          Every maze and butterfly here is drawn from the world of a picture book about a little
          butterfly learning to be brave. <a href="/book/">Sissy&rsquo;s story</a> is a gentle
          read-aloud whenever you&rsquo;re ready.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <p class="mx-auto max-w-2xl text-center text-lg">
        Prefer them delivered? Our <a href="/newsletter/">free newsletter</a> sends new printables
        and gentle updates for grown-ups — never for children.
      </p>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
