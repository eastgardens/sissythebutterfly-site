---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Feature from '@components/Feature.astro'
import CallToAction from '@components/CallToAction.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Image } from 'astro:assets'
import heroImage from '@assets/img/sissy-hero.png'
import sceneMeadow from '@assets/img/scenes/scene-sunny-meadow.png'
import sceneGarden from '@assets/img/scenes/scene-butterfly-garden.png'
import scenePond from '@assets/img/scenes/scene-pond.png'
import sceneWaterfall from '@assets/img/scenes/scene-waterfall.png'
import sceneSunset from '@assets/img/scenes/scene-sunset-meadow.png'
import sceneForest from '@assets/img/scenes/scene-enchanted-forest.png'

const scenes = [
  { src: sceneMeadow, label: 'The sunny meadow', alt: 'A sunny green meadow with a winding path and wildflowers.' },
  { src: sceneGarden, label: 'The butterfly garden', alt: 'A bright garden full of big flowers and butterflies.' },
  { src: scenePond, label: 'The lily pond', alt: 'A calm blue pond dotted with lily pads.' },
  { src: sceneWaterfall, label: 'The waterfall', alt: 'A little waterfall tumbling over mossy rocks.' },
  { src: sceneSunset, label: 'Sunset meadow', alt: 'Rolling hills glowing orange and pink at sunset.' },
  { src: sceneForest, label: 'The Enchanted Forest', alt: 'A magical forest path lit with glowing lanterns.' },
]

/**
 * Home — character-first, alive on load (WEBSITE-BUILD-SPEC §2).
 * Hero = Jen's real Book-1 art (2.3b); Jen's voice pass at 2.3f.
 */
---

<DefaultLayout
  title="Sissy the Butterfly — gentle adventures, free printables, and read-aloud moments"
  useTitleTemplate={false}
>
  <section class="hero my-24">
    <div class="container">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div class="flex flex-col items-center gap-8 text-center lg:items-start lg:text-left">
          <Heading level="h1" class="text-6xl lg:text-7xl">
            Well hello, friend. I’m <span class="text-gradient">Sissy the Butterfly</span>.
          </Heading>
          <p class="max-w-2xl text-2xl">
            I live in a big green meadow with my best friend Addy, and we are always finding
            something small and wonderful to explore. Would you like to come along?
          </p>
          <div class="flex flex-col gap-3 min-[500px]:flex-row">
            <Link href="/printables/" class="button">Free printables &amp; activities</Link>
            <Link href="/meet-jen/" class="button color-secondary">Meet Jen, our author</Link>
          </div>
        </div>
        <Image
          src={heroImage}
          alt="Sissy the Butterfly, a smiling butterfly with purple and pink wings and two pink bows, standing in a flowery meadow."
          width="700"
          loading="eager"
          fetchpriority="high"
          class="hero-art"
        />
      </div>
    </div>
  </section>

  <section class="my-32">
    <div class="container">
      <Heading level="h2" class="mb-8">Made by a teacher, for families</Heading>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        <Feature icon="lucide:flower-2" title="Gentle stories">
          Small brave moments from the meadow — stories to read together, never rushed.
        </Feature>
        <Feature icon="lucide:printer" title="Free printables">
          Coloring pages, puzzles, crafts, songs, and games. Print one and play today.
        </Feature>
        <Feature icon="lucide:heart-handshake" title="Parents first">
          Everything here is made for grown-ups to share with their children. No accounts,
          no ads, nothing collected from kids.
        </Feature>
      </div>
    </div>
  </section>

  <section class="my-32">
    <div class="container">
      <Heading level="h2" class="mb-8">Places to explore in the meadow</Heading>
      <ul class="scene-grid">
        {
          scenes.map((scene) => (
            <li class="scene-tile">
              <Image src={scene.src} alt={scene.alt} width="240" class="scene-img" />
              <span class="scene-label">{scene.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="my-32">
    <div class="container">
      <Heading level="h2" class="mb-4">Fresh this week</Heading>
      <p class="mb-6 max-w-2xl text-lg">
        A new free activity lands here every week. First up: the meadow is getting ready —
        our first printable pack arrives with the site’s grand opening.
      </p>
      <Link href="/printables/">See what’s in the activity garden</Link>
    </div>
  </section>

  <CallToAction title="Read the book that started it all" link="/book/" linkText="About the book" />

  <!-- Email signup lands HERE at 2.3d — gated on domain authentication (spec §3 / runbook 037). -->
</DefaultLayout>

<style>
  .hero-art {
    border-radius: 1.5rem;
    height: auto;
    max-width: 100%;
  }

  .scene-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .scene-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .scene-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .scene-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .scene-img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    border: 3px solid var(--color-primary-100);
  }

  .scene-label {
    font-weight: 700;
    font-size: 0.95rem;
  }
</style>
