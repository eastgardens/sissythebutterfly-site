---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Feature from '@components/Feature.astro'
import CallToAction from '@components/CallToAction.astro'
import NewsletterCallout from '@components/NewsletterCallout.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Image } from 'astro:assets'
import { seasonBanner } from '@config/season'
import heroImage from '@assets/img/cast-group-meadow.png'
import { PLACES } from '@data/places'

/**
 * Home — character-first, alive on load (WEBSITE-BUILD-SPEC §2).
 * Hero = Jen's real Book-1 art (2.3b); Jen's voice pass at 2.3f.
 * Seasonal ribbon = build-time season (config/season.ts); a monthly deploy cron flips it.
 */
const season = seasonBanner()
---

<DefaultLayout
  title="Sissy the Butterfly — gentle adventures, free printables, and read-aloud moments"
  useTitleTemplate={false}
  hideFooterNewsletter={true}
  image={heroImage}
  imageAlt="Sissy, Addy, Buddy, and Flitter together in a sunny flowery meadow."
>
  <section class="season-ribbon" aria-label={`This season in the meadow: ${season.season}`}>
    <Image src={season.image} alt="" width="1000" loading="eager" class="season-bg" aria-hidden="true" />
    <div class="container">
      <p class="season-greeting">
        <span aria-hidden="true">{season.emoji}</span> {season.greeting}
      </p>
    </div>
  </section>

  <section class="hero my-24">
    <div class="container">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div class="flex flex-col items-center gap-8 text-center lg:items-start lg:text-left">
          <Heading level="h1" class="text-[var(--font-size-6)] leading-tight">
            Well hello, friend. I’m <span class="text-gradient">Sissy the Butterfly</span>.
          </Heading>
          <p class="max-w-2xl text-2xl">
            I live in a big green meadow with my best friend Addy, my little brother Buddy, and
            his firefly Flitter. We are always finding something small and wonderful to explore.
            Would you like to come along?
          </p>
          <div class="flex flex-col gap-3 min-[500px]:flex-row">
            <Link href="/printables/" class="button">Free printables &amp; activities</Link>
            <Link href="/meet-jen/" class="button color-secondary">Meet Jen, our author</Link>
          </div>
        </div>
        <Image
          src={heroImage}
          alt="Sissy, Addy, Buddy the grasshopper, and Flitter the firefly together in a sunny flowery meadow."
          width="720"
          loading="eager"
          fetchpriority="high"
          class="hero-art"
        />
      </div>
    </div>
  </section>

  <NewsletterCallout
    title="Free printables in your inbox"
    text="Join grown-ups getting Sissy’s newest coloring pages, activities, and gentle read-aloud ideas — free, and never anything collected from kids."
  />

  <section class="my-32">
    <div class="container">
      <Heading level="h2" class="mb-8">Made by a teacher, for families</Heading>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        <Feature icon="lucide:flower-2" title="Gentle stories">
          Small brave moments from the meadow — stories to read together, never rushed.
        </Feature>
        <Feature icon="lucide:printer" title="Free printables">
          Coloring pages, puzzles, crafts, songs, and games. Print one and play today.
        </Feature>
        <Feature icon="lucide:heart-handshake" title="Parents first">
          Everything here is made for grown-ups to share with their children. No accounts,
          no ads, nothing collected from kids.
        </Feature>
      </div>
    </div>
  </section>

  <section class="my-32">
    <div class="container">
      <Heading level="h2" class="mb-2">Places to explore in the meadow</Heading>
      <p class="scene-intro mb-8">
        Tap a place to visit it — each one has a gentle story, a look-and-find, and free printables.
        Collect all six to become a <Link href="/meadow/">Meadow Explorer</Link>.
      </p>
      <ul class="scene-grid">
        {
          PLACES.map((place) => (
            <li>
              <a class="scene-tile" href={`/meadow/${place.slug}/`}>
                <Image src={place.image} alt={place.alt} width="560" class="scene-img" />
                <span class="scene-label">{place.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="scene-map-cta mt-8">
        <Link href="/meadow/">See the whole Adventure Map →</Link>
      </p>
    </div>
  </section>

  <section class="my-32">
    <div class="container">
      <Heading level="h2" class="mb-4">Fresh this week</Heading>
      <p class="mb-6 max-w-2xl text-lg">
        A new free activity lands here every week. First up: the meadow is getting ready —
        our first printable pack arrives with the site’s grand opening.
      </p>
      <Link href="/printables/">See what’s in the activity garden</Link>
    </div>
  </section>

  <CallToAction title="Read the book that started it all" link="/book/" linkText="About the book" />
</DefaultLayout>

<style>
  /* Seasonal ribbon — a slim full-bleed band; the painterly scene sits behind a scrim so the
     greeting stays legible and mild upscaling of the 701px source is hidden. Auto-flips by season
     (config/season.ts) at build time. */
  .season-ribbon {
    position: relative;
    overflow: hidden;
    min-height: 120px;
    display: flex;
    align-items: center;
  }

  .season-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .season-ribbon::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(64, 12, 159, 0.78) 0%, rgba(64, 12, 159, 0.45) 55%, rgba(64, 12, 159, 0.15) 100%);
  }

  .season-ribbon .container {
    position: relative;
    z-index: 1;
  }

  .season-greeting {
    margin: 0;
    padding: 1rem 0;
    color: #fff;
    font-weight: 700;
    font-size: clamp(1.05rem, 2.5vw, 1.5rem);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
  }

  .hero-art {
    border-radius: 1.5rem;
    height: auto;
    max-width: 100%;
  }

  .scene-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (min-width: 1024px) {
    .scene-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .scene-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  .scene-img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    border: 3px solid var(--color-primary-100);
    transition: transform 0.15s ease;
  }

  .scene-tile:hover .scene-img,
  .scene-tile:focus-visible .scene-img {
    transform: translateY(-4px);
  }

  .scene-tile:focus-visible {
    outline: 3px solid var(--color-primary-400);
    outline-offset: 4px;
    border-radius: 1rem;
  }

  .scene-tile:hover .scene-label {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    .scene-img {
      transition: none;
    }
    .scene-tile:hover .scene-img,
    .scene-tile:focus-visible .scene-img {
      transform: none;
    }
  }

  .scene-label {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .scene-intro {
    max-width: 44rem;
    font-size: 1.1rem;
  }
</style>
