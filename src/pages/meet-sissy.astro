---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import Feature from '@components/Feature.astro'
import { Image } from 'astro:assets'
import duo from '@assets/img/sissy-addy-duo.png'
import addyCast from '@assets/img/addy-cast.png'
import sissyCast from '@assets/img/sissy-cast.png'
import buddyCast from '@assets/img/buddy-cast.png'
import flitterCast from '@assets/img/flitter-cast.png'

/**
 * Meet Sissy & Friends — cast from canon (WEBSITE-BUILD-SPEC §2). Sissy/Addy = real Book-1 art;
 * Buddy (grasshopper) + Flitter (firefly) = Jen-approved design art (2026-07-12), an evolving tier.
 * The garden bee is held until Jen blesses it — off the page for now (cleared-canon only).
 */
---

<DefaultLayout title="Meet Sissy & Friends" description="Meet Sissy the Butterfly, her best friend Addy, her brother Buddy the grasshopper, and Flitter the firefly — the gentle cast of a teacher-created children's book world.">
  <PageHeader
    title="Meet Sissy & Friends"
    subtitle="Everyone you’ll find fluttering around the meadow."
  />
  <section class="my-24">
    <div class="container">
      <div class="mb-16 flex justify-center">
        <Image
          src={duo}
          alt="Sissy and Addy, two smiling butterflies, standing together in the meadow holding flowers — from their first book."
          width="900"
          class="cast-art"
        />
      </div>
      <div class="mb-16 flex flex-wrap items-end justify-center gap-8">
        <Image
          src={sissyCast}
          alt="Sissy the Butterfly, purple and pink wings with pink bows."
          width="300"
          class="cast-art"
        />
        <Image
          src={addyCast}
          alt="Addy the butterfly, blue and yellow wings with blue bows, flying happily."
          width="300"
          class="cast-art"
        />
        <Image
          src={buddyCast}
          alt="Buddy the grasshopper, green with a satchel, waving hello."
          width="240"
          class="cast-art"
        />
        <Image
          src={flitterCast}
          alt="Flitter the firefly, purple with a white bow and a glowing tail."
          width="220"
          class="cast-art"
        />
      </div>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
        <Feature level="h2" icon="lucide:sparkles" title="Sissy — the careful heart">
          Sissy notices everything: the dew, the wind, the wobble in her own tummy before she
          tries something new. She is learning that brave isn’t about being unafraid — it’s
          about fluttering forward anyway.
        </Feature>
        <Feature level="h2" icon="lucide:zap" title="Addy — the bold spark">
          Sissy’s best friend, first to leap and loudest to cheer. Addy is small but mighty,
          kind to her wingtips, and absolutely certain that everything is more fun with a
          friend watching.
        </Feature>
        <Feature level="h2" icon="lucide:bug" title="Buddy — the quiet strength">
          Sissy’s little brother, a grasshopper with the biggest heart in the meadow. Buddy
          doesn’t say much — he notices instead, loves animals and books, and can fly when he
          needs to, though he mostly likes his feet on the ground.
        </Feature>
        <Feature level="h2" icon="lucide:lightbulb" title="Flitter — a little light">
          Buddy’s firefly friend, who never says a word — her glow does all the talking. Bright
          when she’s happy, dim when she’s sad, and a warm little light in the dark when someone
          needs to find their brave.
        </Feature>
      </div>
    </div>
  </section>
</DefaultLayout>

<style>
  .cast-art {
    border-radius: 1.5rem;
    height: auto;
  }
</style>
