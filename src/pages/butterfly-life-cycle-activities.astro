---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { printables, type Printable } from '@data/printables'
import heroArt from '@assets/img/scenes/scene-sunny-meadow.png'

/**
 * SEO resource page — target cluster: "butterfly life cycle activities for preschoolers".
 * Original, age-appropriate teaching content organized around the four life-cycle stages, each
 * tied to a real free printable. Educational integrity first (the brand claim is child
 * development), links to real category pages + PDFs, soft book link, email capture.
 */
const pick = (slugs: string[]): Printable[] =>
  slugs
    .map((slug) => printables.find((p) => p.slug === slug))
    .filter((p): p is Printable => Boolean(p))

const lifeCycleSet = pick([
  'make-a-paper-butterfly',
  'count-the-meadow-counting-sheet',
  'meadow-friends-coloring-page',
  'butterfly-connect-the-dots',
  'make-your-own-meadow-map',
  'butterfly-teacher-pack-book-one',
])

const pageUrl = new URL('/butterfly-life-cycle-activities/', Astro.site).href
const heroUrl = new URL(heroArt.src, Astro.site).href
const logoUrl = new URL('/favicon-512.png', Astro.site).href

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Butterfly Life Cycle Activities for Preschoolers',
  description:
    'Hands-on butterfly life cycle activities for preschoolers — the four stages explained simply, each paired with a free, teacher-created printable for ages 3-7.',
  image: heroUrl,
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  publisher: {
    '@type': 'Organization',
    name: 'Sissy the Butterfly',
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  datePublished: '2026-07-13',
  dateModified: '2026-07-13',
  mainEntityOfPage: pageUrl,
}

const stages = [
  {
    name: '1. Egg',
    body: 'A mother butterfly lays a tiny egg — smaller than this letter "o" — on a leaf. Point one out on a real leaf if you can, or dot the smallest circle your child can draw. Little hands love how tiny it is.',
  },
  {
    name: '2. Caterpillar (larva)',
    body: 'Out wriggles a hungry caterpillar that eats, and eats, and eats. This is a wonderful counting moment: count the leaves it munches, or the legs it wiggles. Movement idea — inch across the floor like a caterpillar.',
  },
  {
    name: '3. Chrysalis (pupa)',
    body: 'The caterpillar makes a cozy chrysalis and rests while something amazing happens inside. Curl up small and hold very still — a favorite quiet-time game. This is the "being patient" stage, and it is a lovely one to talk about.',
  },
  {
    name: '4. Butterfly',
    body: 'Out come the wings! The new butterfly dries them, then flutters off to the flowers. Make paper wings, flap big and slow, and celebrate the change. This is where our paper-butterfly craft shines.',
  },
]

const faqs = [
  {
    q: 'What are the four stages of the butterfly life cycle?',
    a: 'Egg, caterpillar (larva), chrysalis (pupa), and butterfly (adult). This complete change from one form to a very different one is called metamorphosis.',
  },
  {
    q: 'How do I teach the butterfly life cycle to a preschooler?',
    a: 'Keep it hands-on and short. Act out each stage with your body, pair it with a picture or a craft, and use simple words. Repeat it a few times over the week rather than all at once.',
  },
  {
    q: 'Are these activities good for a preschool classroom?',
    a: 'Yes. They are teacher-created for ages 3 to 7 and work as a read-aloud follow-up, a science-corner station, or a spring-theme unit. Print as many copies as your class needs.',
  },
]
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<DefaultLayout
  title="Butterfly Life Cycle Activities for Preschoolers"
  description="Simple butterfly life cycle activities for preschoolers — the four stages explained, each with a free teacher-created printable for ages 3-7. Hands-on and screen-free."
  image={heroArt}
  imageAlt="A sunny meadow full of flowers where butterflies flutter — the world of Sissy the Butterfly."
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  <PageHeader
    title="Butterfly Life Cycle Activities for Preschoolers"
    subtitle="The four stages, explained simply — with a free, hands-on printable for each one."
    featuredImage={heroArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <p>
          The butterfly life cycle is one of the very best science stories to share with a little
          one — because it is real, it is close by, and it is all about change. An egg becomes a
          caterpillar, a caterpillar becomes a chrysalis, and a chrysalis becomes a butterfly.
          Preschoolers feel that magic in their bones.
        </p>
        <p>
          Below are the four stages in plain words, each paired with a simple activity and a free,
          teacher-created printable. You do not need a science degree — just a few minutes, some
          crayons, and a little wonder.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">The four stages, one at a time</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-6 text-lg">
        {
          stages.map((stage) => (
            <div>
              <Heading level="h3">{stage.name}</Heading>
              <p class="mt-1">{stage.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Free printables for your life cycle unit</Heading>
      <p class="text-lg">
        These teacher-created sheets slot right into the stages above — make the butterfly, count
        the caterpillar's snacks, color the meadow, and draw a habitat of your own.
      </p>
      <PrintableGrid items={lifeCycleSet} />
      <p class="text-lg">
        Want more? Browse all our <a href="/printables/crafts/">butterfly crafts</a>,
        <a href="/printables/puzzles/">counting and puzzle sheets</a>, and
        <a href="/printables/teaching-guides/">classroom teaching guides</a>.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Ways to bring it to life</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <ul class="flex list-disc flex-col gap-2 pl-6">
          <li>
            <strong>Act it out.</strong> Curl up as an egg, inch as a caterpillar, hold still as a
            chrysalis, then flutter as a butterfly. Bodies remember what worksheets forget.
          </li>
          <li>
            <strong>Watch it for real.</strong> A milkweed plant on a windowsill can draw a real
            monarch. Even without one, a walk to spot caterpillars turns a page into a wonder.
          </li>
          <li>
            <strong>Use the change as a feelings talk.</strong> The chrysalis stage is a gentle way
            to talk about waiting, patience, and how being a little scared can come right before
            something wonderful.
          </li>
          <li>
            <strong>Repeat across the week.</strong> Read, craft, count, and act out on different
            days. Preschoolers learn by coming back, not by cramming.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Frequently asked questions</Heading>
      <dl class="mx-auto flex max-w-2xl flex-col gap-6 text-lg">
        {
          faqs.map((item) => (
            <div>
              <dt class="font-bold">{item.q}</dt>
              <dd class="mt-1">{item.a}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto max-w-2xl text-lg">
        <Heading level="h2">A story about change, too</Heading>
        <p class="mt-3">
          The life cycle is really a story about becoming braver and bigger than you started —
          which happens to be exactly what our picture book is about. If your unit sparks some
          questions about being brave, <a href="/book/">the Sissy the Butterfly book</a> makes a
          gentle read-aloud companion. And you can always
          <a href="/free-butterfly-printables/">explore more free butterfly printables</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
