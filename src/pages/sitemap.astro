---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Link } from 'accessible-astro-components'

/**
 * Sitemap — Sissy's real pages (the template's blog/portfolio demo listing replaced, 2.3e).
 */
const pages = [
  { title: 'Home', url: '/', description: 'Sissy says hello — start here.' },
  {
    title: 'Meet Sissy & Friends',
    url: '/meet-sissy/',
    description: 'Sissy, Addy, and everyone fluttering around the meadow.',
  },
  {
    title: 'Printables & Activities',
    url: '/printables/',
    description:
      'Free coloring, crafts, puzzles, activities, teaching guides, make-your-own, and music.',
  },
  { title: 'Coloring', url: '/printables/coloring/', description: 'Free printable coloring pages.' },
  {
    title: 'Crafts',
    url: '/printables/crafts/',
    description: 'Simple kids crafts with household materials.',
  },
  {
    title: 'Puzzles',
    url: '/printables/puzzles/',
    description: 'Mazes, word searches, and matching games.',
  },
  {
    title: 'Activities',
    url: '/printables/activities/',
    description: 'Movement games and garden adventures.',
  },
  {
    title: 'Teaching Guides',
    url: '/printables/teaching-guides/',
    description: 'Teacher-created read-aloud companions and classroom resources.',
  },
  {
    title: 'Make Your Own',
    url: '/printables/make-your-own/',
    description: 'Blank comic panels, song sheets, and maps for young imaginations.',
  },
  {
    title: 'Music & Songs',
    url: '/printables/music/',
    description: 'Lyric and action sheets to sing and wiggle.',
  },
  {
    title: 'Meet Jen',
    url: '/meet-jen/',
    description: 'The teacher, mom, and author behind the butterfly.',
  },
  {
    title: 'For Parents',
    url: '/parents/',
    description: 'Our promises, our safety stance, and how we work.',
  },
  { title: 'The Book', url: '/book/', description: 'Sissy’s first adventure — choose where to buy.' },
  {
    title: 'Newsletter',
    url: '/newsletter/',
    description: 'Free printables and gentle updates by email — for grown-ups.',
  },
  { title: 'Links', url: '/links/', description: 'Everything Sissy, one flutter away.' },
  { title: 'Privacy', url: '/privacy/', description: 'Plain-language privacy policy.' },
  {
    title: 'Accessibility statement',
    url: '/accessibility-statement',
    description: 'Our commitment to a site everyone can use.',
  },
]
---

<DefaultLayout title="Sitemap — Sissy the Butterfly" description="Every page in Sissy the Butterfly's meadow: the book, free printables, characters, the author, and our promises to parents.">
  <PageHeader title="Sitemap" subtitle="Every page in the meadow." />
  <section class="my-24">
    <div class="container">
      <ul class="mx-auto flex max-w-2xl flex-col gap-6">
        {
          pages.map((page) => (
            <li>
              <Link href={page.url} class="text-xl font-bold">
                {page.title}
              </Link>
              <p>{page.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</DefaultLayout>
