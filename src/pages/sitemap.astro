---

<DefaultLayout title="Sitemap — Sissy the Butterfly" description="Every page in Sissy the Butterfly's meadow: the book, free printables, characters, the author, and our promises to parents.">
  <PageHeader title="Sitemap" subtitle="Every page in the meadow." />
  <section class="my-24">
    <div class="container">
      <ul class="mx-auto flex max-w-2xl flex-col gap-6">
        {
          pages.map((page) => (
            <li>
              <Link href={page.url} class="text-xl font-bold">
                {page.title}
              </Link>
              <p>{page.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</DefaultLayout>
