---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import NewsletterCallout from '@components/NewsletterCallout.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Image } from 'astro:assets'
import homeArt from '@assets/img/sissy-addy-home.png'
import bannerArt from '@assets/img/scenes/scene-enchanted-forest.png'
import {
  BOOK_AMAZON,
  BOOK_SECONDARY_RETAILERS,
  BOOK_ALL_RETAILERS,
  BOOK_ISBN,
  BOOK_GTIN13,
} from '@config/book'

/**
 * The Book — the first-party buy page (033; WEBSITE-BUILD-SPEC §2). Amazon leads as the primary
 * buy path so reviews concentrate on one listing (operator call, 2026-07-19); Barnes & Noble +
 * Walmart stay as a small "also available" line. Buy links live in ONE place (`@config/book`).
 * Retailer clicks are the tracked intent events (analytics wiring at 2.3d).
 */
// Book structured data (WEBSITE-BUILD-SPEC §5 — conservative, true-only).
const bookLd = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'Sissy the Butterfly',
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  isbn: BOOK_ISBN,
  gtin13: BOOK_GTIN13,
  offers: BOOK_ALL_RETAILERS.map((retailer) => ({
    '@type': 'Offer',
    url: retailer.href,
    seller: { '@type': 'Organization', name: retailer.name },
  })),
}
---

<DefaultLayout
  title="Sissy the Butterfly — the book"
  description="Sissy the Butterfly, Book 1: a gentle children's story about friendship and finding her courage. See where to buy the book and start your read-aloud adventure."
  image={homeArt}
  imageAlt="Sissy and Addy back home in the meadow, eyes closed and smiling — from the book's happy ending."
>
  <script type="application/ld+json" set:html={JSON.stringify(bookLd)} is:inline />
  <PageHeader
    title="Sissy the Butterfly"
    subtitle="The first adventure from the meadow — a read-aloud for ages 3–7."
    featuredImage={bannerArt}
  />
  <section class="my-24">
    <div class="container">
      <div class="mx-auto flex max-w-2xl flex-col gap-6 text-lg">
        <Image
          src={homeArt}
          alt="Sissy and Addy back home in the meadow, eyes closed and smiling — from the book's happy ending."
          width="800"
          class="book-art"
        />
        <p>
          Sissy’s wings are new, the meadow is big, and being brave is easier said than done.
          The very first Sissy the Butterfly book is a gentle read-aloud about small courage —
          written by a teacher, made for laps, story rugs, and one-more-time bedtimes.
        </p>
        <p>
          It’s a “read it together” kind of book: short enough for tonight, warm enough for
          every night this week.
        </p>
        <Heading level="h2" class="mt-8">Get the book</Heading>
        <div class="buy-primary">
          <Link
            href={BOOK_AMAZON.href}
            isExternal={true}
            class="button"
            data-event={BOOK_AMAZON.event}
          >
            Buy on Amazon
          </Link>
        </div>
        <p class="text-base">
          Also available at{' '}
          {
            BOOK_SECONDARY_RETAILERS.map((retailer, i) => (
              <Fragment>
                {i > 0 && <span aria-hidden="true"> · </span>}
                <Link href={retailer.href} isExternal={true} data-event={retailer.event}>
                  {retailer.name}
                </Link>
              </Fragment>
            ))
          }.
        </p>
        <p class="mt-4 text-base">
          If it earns a spot in the pile, a quick Amazon review helps other families find Sissy —
          and helps the meadow’s five more stories reach their turn.
        </p>
      </div>
    </div>
  </section>
  <NewsletterCallout
    title="Love the book? Get free printables too"
    text="Coloring pages, activities, and read-aloud ideas from Sissy’s meadow — free, sent to grown-ups. A gentle way to keep the story going between pages."
  />
</DefaultLayout>

<style>
  .book-art {
    border-radius: 1.5rem;
    height: auto;
  }
</style>
