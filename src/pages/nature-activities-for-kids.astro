---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { printables, type Printable } from '@data/printables'
import heroArt from '@assets/img/scenes/scene-enchanted-forest.png'

/**
 * SEO resource page — target cluster: "nature activities for kids" / "outdoor activities for
 * preschoolers" / "backyard scavenger hunt for kids". Curates our real outdoor + nature sheets with
 * genuine guidance on getting little ones outside and noticing the world. Gentle, teacher-created.
 */
const pick = (slugs: string[]): Printable[] =>
  slugs
    .map((slug) => printables.find((p) => p.slug === slug))
    .filter((p): p is Printable => Boolean(p))

const outdoorSet = pick(['backyard-butterfly-hunt-outdoor-card', 'i-spy-the-meadow'])
const natureSet = pick([
  'nature-word-search',
  'flower-connect-the-dots',
  'design-your-own-butterfly-wings',
  'make-your-own-meadow-map',
])

const pageUrl = new URL('/nature-activities-for-kids/', Astro.site).href
const heroUrl = new URL(heroArt.src, Astro.site).href
const logoUrl = new URL('/favicon-512.png', Astro.site).href

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Nature Activities for Kids',
  description:
    'Free nature activities for kids ages 3-7 — a backyard scavenger hunt, an I-Spy count-and-find, a nature word search, and draw-your-own meadow sheets. Teacher-created, print and explore.',
  image: heroUrl,
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  publisher: {
    '@type': 'Organization',
    name: 'Sissy the Butterfly',
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  datePublished: '2026-07-16',
  dateModified: '2026-07-16',
  mainEntityOfPage: pageUrl,
}

const faqs = [
  {
    q: 'What are good nature activities for a preschooler?',
    a: 'The best ones ask a child to slow down and notice: a scavenger hunt for a red leaf or a smooth stone, counting how many birds land on a wire, or drawing the shape of a cloud. Noticing is the whole skill, and a young child is already very good at it.',
  },
  {
    q: 'What if we do not have a big backyard?',
    a: 'You need far less space than you think. A single flowerpot, a crack in the pavement with a weed in it, or a walk to the same tree each week all work. Nature is not a place you drive to — it is whatever is growing nearest to you.',
  },
  {
    q: 'How do I keep an outdoor activity from falling apart?',
    a: 'Bring one small job. A child with a paper to fill in or a single thing to find will stay with it far longer than a child told to go and play. Print a sheet, hand it over, and let the hunt do the work.',
  },
  {
    q: 'Are these nature printables free?',
    a: 'Yes — every sheet here is a free, teacher-created PDF. Print on regular letter-size paper. A clipboard makes them easier to fill in outdoors, but a hard book works just as well.',
  },
]
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<DefaultLayout
  title="Nature Activities for Kids"
  description="Free nature activities for kids ages 3-7 — a backyard scavenger hunt, an I-Spy count-and-find, a nature word search, and draw-your-own meadow sheets. Teacher-created, print and explore."
  image={heroArt}
  imageAlt="A green, leafy forest scene from the world of Sissy the Butterfly."
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  <PageHeader
    title="Nature Activities for Kids"
    subtitle="A scavenger hunt, a count-and-find, and a few good reasons to go outside — free to print, for ages 3 to 7."
    featuredImage={heroArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <p>
          The best nature activity for a young child is almost never the one with the most steps. It
          is the one that asks them to stop and look closely — at a beetle crossing the path, at the
          underside of a leaf, at how many petals a flower really has. Children are natural
          noticers; a good sheet just gives that noticing somewhere to land.
        </p>
        <p>
          Everything below is made to take outside. Print one, hand it over, and follow your little
          one into the garden, the park, or the patch of green nearest your door. All free, all
          teacher-created.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Take-it-outside activities</Heading>
      <p class="text-lg">
        A gentle backyard scavenger hunt and a count-and-find — both made to slow a child down and
        point their eyes at the small things.
      </p>
      <PrintableGrid items={outdoorSet} />
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Nature sheets for the kitchen table</Heading>
      <p class="text-lg">
        For rainy days, or for after the walk when little legs are tired — a nature word search, a
        flower to draw dot by dot, and two make-your-own sheets where your child is the one in
        charge.
      </p>
      <PrintableGrid items={natureSet} />
      <p class="text-lg">
        More in the full <a href="/printables/puzzles/">puzzles collection</a> and the
        <a href="/printables/make-your-own/">make-your-own collection</a>.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Ways to make it stick</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <ul class="flex list-disc flex-col gap-2 pl-6">
          <li>
            <strong>Wonder out loud.</strong> &ldquo;I wonder where that ant is going&rdquo; invites
            a child in far better than &ldquo;look at the ant.&rdquo; Curiosity is caught, not
            taught.
          </li>
          <li>
            <strong>Follow their leaf.</strong> If they stop at a puddle for ten minutes, the puddle
            is the lesson. The plan is only there to get you both out the door.
          </li>
          <li>
            <strong>Collect, then sort.</strong> A pocket of stones and leaves becomes a table-top
            activity later — biggest to smallest, smooth and rough, by color. The walk keeps giving.
          </li>
          <li>
            <strong>Go in every kind of weather.</strong> A drizzle, a wind, a frost — each turns
            the same path into a new place. There is no bad weather, only exciting weather and the
            right coat.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Questions grown-ups ask</Heading>
      <div class="mx-auto max-w-2xl">
        <dl class="flex flex-col gap-6">
          {
            faqs.map((item) => (
              <div>
                <dt class="text-lg font-bold">{item.q}</dt>
                <dd class="mt-2 text-lg">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">More gentle guides</Heading>
      <ul class="mx-auto flex max-w-2xl list-disc flex-col gap-3 pl-6 text-lg">
        <li>
          <a href="/butterfly-life-cycle-activities/">Butterfly life cycle activities for preschoolers</a>
        </li>
        <li><a href="/screen-free-activities-for-kids/">Screen-free activities for kids ages 3-7</a></li>
        <li><a href="/free-butterfly-printables/">All our free butterfly printables</a></li>
      </ul>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto max-w-2xl text-lg">
        <Heading level="h2">The meadow comes from a story</Heading>
        <p class="mt-3">
          The flowers and fireflies your child is hunting for all live in a picture book about a
          little butterfly learning to be brave. <a href="/book/">Sissy&rsquo;s story</a> is a
          gentle read-aloud whenever you&rsquo;re ready.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <p class="mx-auto max-w-2xl text-center text-lg">
        Prefer them delivered? Our <a href="/newsletter/">free newsletter</a> sends new printables
        and gentle updates for grown-ups — never for children.
      </p>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
