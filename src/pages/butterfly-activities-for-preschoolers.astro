---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PrintableGrid from '@components/PrintableGrid.astro'
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'
import { printables, type Printable } from '@data/printables'
import heroArt from '@assets/img/scenes/scene-butterfly-garden.png'

/**
 * SEO resource page — target cluster: "butterfly activities for preschoolers" / "butterfly theme
 * preschool" / "butterfly unit for kids". A themed HUB for a butterfly week: one activity per
 * learning corner, each tied to a real printable, cross-linking the deeper guides (life cycle,
 * crafts, songs, calm-down) rather than repeating them. Gentle, teacher-created.
 */
const pick = (slugs: string[]): Printable[] =>
  slugs
    .map((slug) => printables.find((p) => p.slug === slug))
    .filter((p): p is Printable => Boolean(p))

const themeSet = pick([
  'meadow-friends-coloring-page',
  'make-a-paper-butterfly',
  'count-the-meadow-counting-sheet',
  'butterfly-maze',
  'the-flutter-song-lyric-and-action-sheet',
  'rainbow-breaths-calm-down-card',
])

const pageUrl = new URL('/butterfly-activities-for-preschoolers/', Astro.site).href
const heroUrl = new URL(heroArt.src, Astro.site).href
const logoUrl = new URL('/favicon-512.png', Astro.site).href

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Butterfly Activities for Preschoolers',
  description:
    'A ready-made butterfly theme for preschoolers ages 3-7 — coloring, a paper craft, counting, a maze, an action song, and a calm-down card, each a free teacher-created printable.',
  image: heroUrl,
  author: { '@type': 'Person', name: 'Jen Logsdon' },
  publisher: {
    '@type': 'Organization',
    name: 'Sissy the Butterfly',
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  datePublished: '2026-07-16',
  dateModified: '2026-07-16',
  mainEntityOfPage: pageUrl,
}

const corners = [
  {
    name: 'Art corner: color the meadow',
    body: 'Start soft. A coloring page lets a child settle in, warm up their hand, and meet the characters before anything is asked of them. Talk about which butterfly is which while they color.',
  },
  {
    name: 'Making table: a paper butterfly',
    body: 'Fold, cut, and decorate a butterfly from a single sheet. It is the centerpiece of the whole theme — and a lovely lead-in to talking about how a caterpillar becomes a butterfly.',
  },
  {
    name: 'Number nook: count the meadow',
    body: 'Count the butterflies, flowers, and stars, then write the number. Butterflies are wonderful to count because there are always more to find, and no two children count them the same way.',
  },
  {
    name: 'Puzzle spot: the butterfly maze',
    body: 'Steer a finger, then a crayon, from start to finish. A maze is quiet, focused fun that builds the pencil control writing will lean on later.',
  },
  {
    name: 'Circle time: the Flutter Song',
    body: 'Bring everyone together with a sing-and-move song set to a tune you already half-know, with an action for every line. It is the easiest way to turn wiggles into part of the plan.',
  },
  {
    name: 'Quiet corner: a calm-down card',
    body: 'End on a gentle note. A rainbow-breathing card gives a busy group a soft place to land — and a tool they can reach for on a hard day, long after the theme is over.',
  },
]

const faqs = [
  {
    q: 'How do I plan a butterfly theme for preschoolers?',
    a: 'Spread it across the week rather than cramming it into a day. Pick one activity per learning corner — art, making, numbers, a puzzle, a song, and a quiet moment — and let the butterfly tie them together. The six sheets below give you exactly that.',
  },
  {
    q: 'What age is a butterfly theme best for?',
    a: 'Roughly ages 3 to 7. Younger children lean into the coloring, craft, and song; older ones enjoy the counting, the maze, and talking about the life cycle. Everything here is made to stretch gently across that range.',
  },
  {
    q: 'Can I use this in a classroom or a co-op?',
    a: 'Yes. It is teacher-created for exactly that — a spring unit, a science-corner week, or a read-aloud follow-up. Print as many copies as your group needs for non-commercial classroom and home use.',
  },
  {
    q: 'Are all these butterfly activities free?',
    a: 'Yes — every sheet here is a free, teacher-created PDF. Print on regular letter-size paper, black-and-white works beautifully, and nothing is ever moved behind a paywall.',
  },
]
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<DefaultLayout
  title="Butterfly Activities for Preschoolers"
  description="A ready-made butterfly theme for preschoolers ages 3-7 — coloring, a paper craft, counting, a maze, an action song, and a calm-down card, each a free teacher-created printable."
  image={heroArt}
  imageAlt="A bright butterfly garden full of big flowers, from the world of Sissy the Butterfly."
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />

  <PageHeader
    title="Butterfly Activities for Preschoolers"
    subtitle="A ready-made butterfly theme — one gentle activity for every corner of the day, free to print, for ages 3 to 7."
    featuredImage={heroArt}
  />

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto flex max-w-2xl flex-col gap-4 text-lg">
        <p>
          Few themes suit a preschooler quite like a butterfly. It is beautiful, it is real, it is
          all about change — and it stretches happily across a whole week of learning, from the art
          table to circle time to the quiet corner at the end of the day.
        </p>
        <p>
          Here is a ready-made butterfly theme built from six free, teacher-created printables — one
          for each corner below. Do them in order or dip in wherever your day takes you.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">A butterfly week, corner by corner</Heading>
      <div class="mx-auto flex max-w-2xl flex-col gap-6 text-lg">
        {
          corners.map((corner) => (
            <div>
              <Heading level="h3">{corner.name}</Heading>
              <p class="mt-1">{corner.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">The six free printables</Heading>
      <p class="text-lg">
        Everything you need for the corners above, ready to print — a coloring page, a paper craft,
        a counting sheet, a maze, an action song, and a calm-down card.
      </p>
      <PrintableGrid items={themeSet} />
      <p class="text-lg">
        Want the whole meadow? Browse all our <a href="/free-butterfly-printables/">free butterfly
        printables</a>.
      </p>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Go deeper on any corner</Heading>
      <p class="text-lg">
        Each of these gentle guides expands one part of the theme into a full afternoon:
      </p>
      <ul class="mx-auto flex max-w-2xl list-disc flex-col gap-3 pl-6 text-lg">
        <li>
          <a href="/butterfly-life-cycle-activities/">Butterfly life cycle activities</a> — the four
          stages, explained simply, each with a printable.
        </li>
        <li>
          <a href="/butterfly-crafts-for-kids/">Butterfly crafts for kids</a> — more make-alongs
          using things you already have at home.
        </li>
        <li>
          <a href="/kids-songs-with-actions/">Kids songs with actions</a> — the Flutter Song and
          more, with a movement for every line.
        </li>
        <li>
          <a href="/calm-down-activities-for-kids/">Calm-down activities for kids</a> — gentle
          breathing and grounding cards for big feelings.
        </li>
      </ul>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2">Questions grown-ups ask</Heading>
      <div class="mx-auto max-w-2xl">
        <dl class="flex flex-col gap-6">
          {
            faqs.map((item) => (
              <div>
                <dt class="text-lg font-bold">{item.q}</dt>
                <dd class="mt-2 text-lg">{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <div class="mx-auto max-w-2xl text-lg">
        <Heading level="h2">The theme comes from a story</Heading>
        <p class="mt-3">
          Sissy is a little butterfly learning to be brave, and this whole theme grew from her
          meadow. <a href="/book/">Her picture book</a> makes a gentle read-aloud to open or close
          the week, whenever you&rsquo;re ready.
        </p>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="container space-content">
      <Heading level="h2" class="text-center">Free printables in your inbox</Heading>
      <p class="mx-auto max-w-2xl text-center text-lg">
        Prefer them delivered? Our <a href="/newsletter/">free newsletter</a> sends new printables
        and gentle updates for grown-ups — never for children.
      </p>
      <NewsletterSignup />
    </div>
  </section>
</DefaultLayout>
