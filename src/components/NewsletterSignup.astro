---
import { newsletterLive, MAILERLITE_ACTION, MAILERLITE_EMAIL_FIELD } from '@config/funnel'

/**
 * Newsletter signup (runbook 2.3d) — gated behind the deliverability gate (037).
 * When `newsletterLive` is false it shows an honest "almost ready" state instead of collecting
 * addresses it can't yet email safely. When live, it's a plain HTML form that POSTs straight to
 * MailerLite (no backend, works on a static host). Parent-facing; a real adult opts in.
 */
---

{
  newsletterLive ? (
    <form
      class="newsletter-form"
      action={MAILERLITE_ACTION}
      method="post"
      target="_blank"
      rel="noopener"
    >
      <label for="newsletter-email" class="newsletter-label">
        Your email
      </label>
      <div class="newsletter-row">
        <input
          id="newsletter-email"
          type="email"
          name={MAILERLITE_EMAIL_FIELD}
          autocomplete="email"
          required
          placeholder="grown-up@example.com"
          class="newsletter-input"
        />
        <button type="submit" class="button" data-event="newsletter_submit">
          Send me printables
        </button>
      </div>
      {/* Honeypot: real people leave this empty; bots fill it. Hidden from humans + AT. */}
      <input
        type="text"
        name="hp_website"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="newsletter-hp"
      />
      {/* MailerLite's embedded-form required hidden fields (from the form's HTML embed code). */}
      <input type="hidden" name="ml-submit" value="1" />
      <input type="hidden" name="anticsrf" value="true" />
      <p class="newsletter-fineprint">
        For grown-ups. Free printables and gentle updates from the meadow — no spam, unsubscribe
        anytime. We never collect anything from children. See our <a href="/privacy/">privacy
        promise</a>.
      </p>
      {/* Filled in by the submit intercept below; aria-live so screen readers hear the outcome. */}
      <p class="newsletter-status" role="status" aria-live="polite" hidden></p>
    </form>
  ) : (
    <div class="newsletter-soon" role="status">
      <p class="newsletter-soon-title">The meadow's mailing list is almost ready. 🦋</p>
      <p>
        We're getting everything set up so our first hello lands in your inbox — not your spam
        folder. Check back soon, or find us on social in the meantime.
      </p>
    </div>
  )
}

<script>
  // 🔴 WHY THIS EXISTS (operator report, 2026-07-16): real subscribers were landing on a raw
  // `{"success":true}` page — the plain-form POST navigates the browser to MailerLite's JSON
  // endpoint. This intercept posts in the background and shows a human thank-you inline instead.
  // The plain form stays as the no-JS fallback (target="_blank", so those users keep this page).
  document.querySelectorAll<HTMLFormElement>('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault()
      const status = form.querySelector<HTMLElement>('.newsletter-status')
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]')
      const honeypot = form.querySelector<HTMLInputElement>('input[name="hp_website"]')
      const show = (message: string) => {
        if (status) {
          status.textContent = message
          status.hidden = false
        }
      }
      // A filled honeypot = a bot: pretend success, send nothing.
      if (honeypot && honeypot.value.trim() !== '') {
        show('Thank you! Check your inbox to confirm. 🦋')
        return
      }
      if (button) button.disabled = true
      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        })
        // MailerLite answers {"success":true}; anything else is a real failure worth admitting.
        const body = await response.json().catch(() => null)
        if (response.ok && body && body.success === true) {
          show('Almost there! We just sent a confirmation email — tap the link inside and the printables are yours. 🦋')
          form.querySelectorAll('input[type="email"]').forEach((el) => ((el as HTMLInputElement).value = ''))
        } else {
          show('Hmm, that did not go through. Please try again in a moment.')
          if (button) button.disabled = false
        }
      } catch {
        show('Hmm, that did not go through. Please check your connection and try again.')
        if (button) button.disabled = false
      }
    })
  })
</script>

<style>
  .newsletter-form,
  .newsletter-soon {
    max-width: 32rem;
    margin-inline: auto;
  }
  .newsletter-label {
    display: block;
    font-weight: 700;
    margin-block-end: 0.5rem;
  }
  .newsletter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .newsletter-input {
    flex: 1 1 14rem;
    padding: 0.85rem 1rem;
    border: 3px solid var(--color-primary-300);
    border-radius: 999px;
    font-size: 1rem;
  }
  .newsletter-input:focus-visible {
    outline: 3px solid var(--color-secondary-400);
    outline-offset: 2px;
  }
  .newsletter-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .newsletter-fineprint {
    margin-block-start: 0.9rem;
    font-size: 0.9rem;
  }
  .newsletter-status {
    margin-block-start: 0.9rem;
    padding: 0.85rem 1.1rem;
    border-radius: 0.9rem;
    background: var(--color-primary-100);
    border: 2px solid var(--color-primary-300);
    font-weight: 600;
  }
  .newsletter-soon {
    text-align: center;
    padding: 2rem;
    border: 2px dashed var(--color-primary-300);
    border-radius: 1.25rem;
  }
  .newsletter-soon-title {
    font-weight: 700;
    font-size: 1.25rem;
    margin-block-end: 0.5rem;
  }
</style>
