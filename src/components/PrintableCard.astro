---
import { Heading } from 'accessible-astro-components'
import type { Printable } from '@data/printables'

/**
 * PrintableCard — one downloadable printable in the category grid.
 *
 * The thumbnail + the "Download (PDF)" button both carry the [data-event] click-shim attribute
 * (runbook 2.3d) so the provider-agnostic tracker queues a `printable_download_<slug>` event.
 * The PDF is a same-origin static asset under /printables/, so the `download` attribute saves it
 * directly — no email wall today (the email gate is 037-gated; see src/data/printables.ts).
 */
interface Props {
  item: Printable
}

const { item } = Astro.props
---

<article class="printable-card">
  <a
    href={item.pdf}
    download
    data-event={item.downloadEvent}
    class="printable-card__thumb-link"
    aria-label={`Download ${item.title} (PDF)`}
  >
    <img
      src={item.thumb}
      alt={item.alt}
      width={item.thumbWidth}
      height={item.thumbHeight}
      loading="lazy"
      decoding="async"
      class="printable-card__thumb"
    />
  </a>
  <div class="printable-card__body">
    <Heading level="h3" class="printable-card__title">{item.title}</Heading>
    <p class="printable-card__blurb">{item.blurb}</p>
    <p class="printable-card__age">Ages {item.ageBand}</p>
    <a href={item.pdf} download data-event={item.downloadEvent} class="button printable-card__button">
      Download (PDF)
    </a>
  </div>
</article>

<style>
  .printable-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--border-color-subtle);
    border-radius: 1rem;
    background-color: light-dark(var(--color-neutral-100), var(--color-neutral-900));
  }

  .printable-card__thumb-link {
    display: block;
    background-color: light-dark(var(--color-neutral-200), var(--color-neutral-800));
    border-bottom: 1px solid var(--border-color-subtle);
  }

  .printable-card__thumb {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 17 / 22; /* US-letter portrait — reserves space so the grid never reflows */
    object-fit: contain;
  }

  .printable-card__body {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
  }

  .printable-card__title {
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .printable-card__blurb {
    flex: 1 1 auto;
    font-size: 1rem;
  }

  .printable-card__age {
    font-size: 0.9rem;
    font-weight: 600;
    color: light-dark(var(--color-primary-400), var(--color-primary-200));
  }

  .printable-card__button {
    align-self: flex-start;
    margin-top: 0.5rem;
  }
</style>
