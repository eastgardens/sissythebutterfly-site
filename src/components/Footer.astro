---
import CallToAction from './CallToAction.astro'
import Logo from './Logo.astro'
import themeConfig from '@theme-config'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * Footer — Sissy's own (the template's demo footer fully replaced, 2.3e).
 */
const currentYear = new Date().getFullYear()
---

<footer>
  <CallToAction
    title="Free printables are coming to the meadow"
    link="/printables/"
    linkText="Visit the activity garden"
  />
  <section class="py-20">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Explore</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href="/printables/">Printables &amp; activities</Link></li>
          <li><Link href="/meet-sissy/">Meet Sissy &amp; Friends</Link></li>
          <li><Link href="/book/">The book</Link></li>
          <li><Link href="/links/">All our links</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">For grown-ups</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href="/meet-jen/">Meet Jen, the author</Link></li>
          <li><Link href="/parents/">For parents</Link></li>
          <li><Link href="/privacy/">Privacy</Link></li>
          <li><Link href="/accessibility-statement">Accessibility</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Find us</Heading>
        <ul class="flex flex-col gap-2">
          {
            themeConfig.socials.map((social) => (
              <li>
                <Link isExternal href={social.href} class="flex items-center gap-2">
                  <Icon aria-hidden="true" name={social.icon} size="20" />
                  {social.label}
                </Link>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" />
        <p class="leading-[1.75]">
          Teacher-created stories and printables for parents, caregivers, and little
          wonder-finders everywhere.
        </p>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="container flex flex-col items-center gap-2 text-center">
      <p>&copy; {currentYear} Jen Logsdon · Sissy the Butterfly</p>
      <p class="text-sm">Made with love (and reviewed by a real human) in the meadow.</p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
