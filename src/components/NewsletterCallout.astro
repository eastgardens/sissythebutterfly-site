---
import NewsletterSignup from '@components/NewsletterSignup.astro'
import { Heading } from 'accessible-astro-components'

/**
 * NewsletterCallout — the PROMINENT, branded email-capture band (2026-07-19). Wraps the plain
 * NewsletterSignup form in an emphasized on-brand panel for high-intent spots (home hero-adjacent,
 * book page, bio-link hub). Parent-facing; a real adult opts in. Copy is overridable per page.
 */
interface Props {
  title?: string
  text?: string
}

const {
  title = 'Get free printables in your inbox',
  text = 'New coloring pages, activities, and gentle read-aloud ideas — sent to grown-ups, never to kids. Always free, unsubscribe any time.',
} = Astro.props
---

<section class="newsletter-callout">
  <div class="container">
    <div class="newsletter-callout-inner">
      <Heading level="h2" class="newsletter-callout-title">{title}</Heading>
      <p class="newsletter-callout-text">{text}</p>
      <NewsletterSignup />
    </div>
  </div>
</section>

<style>
  .newsletter-callout {
    /* full-bleed soft-lavender band so it reads as a distinct, inviting call — not just another
       text section. Light background keeps AA contrast easy with the dark brand heading + body. */
    background: #f3ecff;
    border-block: 1px solid #e0cffb;
    padding-block: 3rem;
  }
  .newsletter-callout-inner {
    max-width: 40rem;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .newsletter-callout-title {
    color: #400c9f;
  }
  .newsletter-callout-text {
    font-size: 1.125rem;
    color: #2a2340;
  }
  @media (prefers-color-scheme: dark) {
    .newsletter-callout {
      background: #241a3d;
      border-block-color: #3d2e63;
    }
    .newsletter-callout-title {
      color: #d9c2ff;
    }
    .newsletter-callout-text {
      color: #ece7f7;
    }
  }
</style>
